generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  DOCTOR
  RECEPTIONIST
}

enum Gender {
  Male
  Female
  Other
}

enum PaymentStatus {
  Paid
  Partial
  Pending
}

enum PaymentMode {
  Cash
  UPI
  Card
  Insurance
}

enum TokenStatus {
  Waiting
  InConsultation
  Done
  Skipped
}

enum MedicineType {
  tablet
  capsule
  liquid
  drops
  cream
  sachet
  injection
  inhaler
  powder
}

enum SubscriptionPlan {
  Basic
  Standard
  Pro
}

enum ClinicStatus {
  Active
  Inactive
  Suspended
}

// ─────────────────────────────────────────────
// SUPER ADMIN / PLATFORM
// ─────────────────────────────────────────────

model SuperAdmin {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("super_admins")
}

// ─────────────────────────────────────────────
// CLINIC (TENANT)
// ─────────────────────────────────────────────

model Clinic {
  id               String           @id @default(uuid())
  name             String
  address          String?
  phone            String?
  mobile           String?
  email            String?
  logo             String?  // clinic logo image URL (Cloudinary) — small, in header corner
  headerImageUrl   String?  // full-width banner that replaces logo+name+address+phone
  hideTextOnHeader Boolean  @default(true)  // when header image uploaded, hide clinic name/address/phone text
  footerImageUrl   String?  // optional footer image URL
  letterheadUrl    String?  // pre-printed letterhead background image URL
  letterheadMode   Boolean  @default(false)  // when true, hides clinic header on print
  tagline          String?
  gst              String?
  opdSeriesPrefix  String?  // custom OPD number prefix e.g. MH, JK
  status           ClinicStatus     @default(Active)
  subscriptionPlan SubscriptionPlan @default(Basic)
  subscriptionEnd  DateTime?
  settings         Json?            // Misc per-clinic config flags (e.g., flagOutOfRangeLabValues). Schemaless on purpose.
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Relations
  users            User[]
  patients         Patient[]
  appointments     Appointment[]
  prescriptions    Prescription[]
  bills            Bill[]
  medicines        Medicine[]
  labTests         LabTest[]
  complaints       Complaint[]
  diagnoses        Diagnosis[]
  adviceOptions    AdviceOption[]
  medicineNotes    MedicineNote[]
  billingItems     BillingItem[]
  templates        PrescriptionTemplate[]
  dosageOptions    DosageOption[]
  timingOptions    TimingOption[]
  pageDesigns      PageDesign[]
  auditLogs        AuditLog[]
  medicalDocuments         MedicalDocument[]
  medicalDocumentTemplates MedicalDocumentTemplate[]
  labResults       LabResult[]

  @@map("clinics")
}

// ─────────────────────────────────────────────
// USER (All clinic staff)
// ─────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  clinicId     String
  name         String
  email        String
  password     String
  role         UserRole
  phone        String?
  qualification String?
  specialization String?
  regNo        String?
  signature    String?  // doctor signature image URL (Cloudinary)
  stamp        String?  // optional doctor stamp/seal image URL
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Flexible permissions (JSON object of booleans)
  permissions  Json     @default("{}")

  // Relations
  clinic       Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  prescriptions Prescription[]
  medicalDocuments MedicalDocument[]
  auditLogs    AuditLog[]
  refreshTokens RefreshToken[]
  passwordResetTokens PasswordResetToken[]

  @@unique([email])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// Password reset tokens — one-time use, 1-hour expiry.
// Scoped to clinic users only (SuperAdmin uses separate contact-based recovery).
model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?  // null = still valid, set = consumed
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// ─────────────────────────────────────────────
// PATIENT
// ─────────────────────────────────────────────

model Patient {
  id                String   @id @default(uuid())
  clinicId          String
  patientCode       String
  prefix            String?  // Mr, Mrs, Ms, Dr, Baby etc.
  name              String
  age               Int?
  dob               DateTime?
  gender            Gender
  phone             String
  email             String?
  address           String?
  bloodGroup        String?
  photo             String?
  existingId        String?  // old patient ID from previous system
  allergies         String[] @default([])
  chronicConditions String[] @default([])
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  clinic            Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments      Appointment[]
  prescriptions     Prescription[]
  bills             Bill[]
  vitalRecords      VitalRecord[]
  medicalDocuments  MedicalDocument[]
  labResults        LabResult[]

  @@unique([clinicId, patientCode])
  @@map("patients")
}

model VitalRecord {
  id        String   @id @default(uuid())
  patientId String
  date      DateTime @default(now())
  bp        String?
  sugar     String?
  weight    String?
  temp      String?
  spo2      String?
  pulse     String?
  notes     String?

  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("vital_records")
}

// ─────────────────────────────────────────────
// APPOINTMENT / TOKEN
// ─────────────────────────────────────────────

model Appointment {
  id          String      @id @default(uuid())
  clinicId    String
  patientId   String
  doctorId    String?
  tokenNo     Int
  tokenDate   DateTime    @db.Date
  status      TokenStatus @default(Waiting)
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  clinic      Clinic      @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient     Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([clinicId, tokenDate, tokenNo])
  @@map("appointments")
}

// ─────────────────────────────────────────────
// MASTER DATA
// ─────────────────────────────────────────────

model Medicine {
  id             String       @id @default(uuid())
  clinicId       String
  name           String
  genericName    String?      // Active ingredient / composition, e.g. "Paracetamol 500mg" — clinic-wide, editable by Doctor/Admin
  type           MedicineType @default(tablet)
  category       String?
  defaultDosage  String?
  defaultDays    Int?
  defaultTiming  String?
  notesEn        String?
  notesHi        String?
  notesMr        String?
  usageCount     Int          @default(0)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())

  clinic         Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  prescriptionMedicines PrescriptionMedicine[]

  @@unique([clinicId, name])
  @@map("medicines")
}

model LabTest {
  id        String   @id @default(uuid())
  clinicId  String
  name      String
  category  String?
  expectedFields Json?  // Array of { key, label, unit, normalLow, normalHigh } — see lib/labTestFields.js
  usageCount Int     @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  prescriptionLabTests PrescriptionLabTest[]
  labResults           LabResult[]

  @@unique([clinicId, name])
  @@map("lab_tests")
}

model Complaint {
  id        String   @id @default(uuid())
  clinicId  String
  nameEn    String
  nameHi    String?
  nameMr    String?
  usageCount Int     @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, nameEn])
  @@map("complaints")
}

model Diagnosis {
  id        String   @id @default(uuid())
  clinicId  String
  nameEn    String
  nameHi    String?
  nameMr    String?
  usageCount Int     @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, nameEn])
  @@map("diagnoses")
}

model AdviceOption {
  id        String   @id @default(uuid())
  clinicId  String
  nameEn    String
  nameHi    String?
  nameMr    String?
  usageCount Int     @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, nameEn])
  @@map("advice_options")
}

model MedicineNote {
  id        String   @id @default(uuid())
  clinicId  String
  nameEn    String
  nameHi    String?
  nameMr    String?
  usageCount Int     @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, nameEn])
  @@map("medicine_notes")
}

model BillingItem {
  id           String   @id @default(uuid())
  clinicId     String
  name         String
  defaultPrice Float    @default(0)
  category     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  clinic       Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  billItems    BillItem[]

  @@unique([clinicId, name])
  @@map("billing_items")
}

model DosageOption {
  id          String   @id @default(uuid())
  clinicId    String
  code        String
  label       String
  timesPerDay Int?
  isActive    Boolean  @default(true)

  clinic      Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, code])
  @@map("dosage_options")
}

model TimingOption {
  id           String   @id @default(uuid())
  clinicId     String
  code         String
  labelEn      String
  labelHi      String?
  labelMr      String?
  isActive     Boolean  @default(true)

  clinic       Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, code])
  @@map("timing_options")
}

// ─────────────────────────────────────────────
// PRESCRIPTION TEMPLATE
// ─────────────────────────────────────────────

model PrescriptionTemplate {
  id          String   @id @default(uuid())
  clinicId    String
  name        String
  complaint   String?
  diagnosis   String?
  advice      String?
  nextVisit   Int?
  labTests    String[] @default([])
  usageCount  Int      @default(0)
  version     Int      @default(1)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clinic      Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  medicines   TemplateMedicine[]

  @@unique([clinicId, name])
  @@map("prescription_templates")
}

model TemplateMedicine {
  id          String   @id @default(uuid())
  templateId  String
  medicineId  String
  dosage      String?
  days        String?  // e.g. '7 days', '2 weeks', '1 month'
  timing      String?
  frequency   String?  // DAILY, ALT_DAYS, EVERY_3D, WEEKLY, SOS
  notesEn     String?
  notesHi     String?
  notesMr     String?
  sortOrder   Int      @default(0)

  template    PrescriptionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("template_medicines")
}

// ─────────────────────────────────────────────
// PRESCRIPTION
// ─────────────────────────────────────────────

model Prescription {
  id           String   @id @default(uuid())
  clinicId     String
  rxNo         String
  date         DateTime @default(now())
  doctorId     String
  patientId    String
  complaint    String?
  diagnosis    String?
  advice       String?
  nextVisit    DateTime?
  templateUsed String?
  printLang    String   @default("en")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clinic       Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  doctor       User     @relation(fields: [doctorId], references: [id])
  patient      Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  medicines    PrescriptionMedicine[]
  labTests     PrescriptionLabTest[]
  labResults   LabResult[]
  bills        Bill[]

  @@unique([clinicId, rxNo])
  @@map("prescriptions")
}

model PrescriptionMedicine {
  id             String   @id @default(uuid())
  prescriptionId String
  medicineId     String
  medicineName   String
  genericName    String?       // Snapshot of Medicine.genericName at save time (keeps old prescriptions stable if master edited later)
  medicineType   MedicineType @default(tablet)
  dosage         String?
  days           String?  // e.g. '7 days', '2 weeks', '1 month'
  timing         String?
  frequency      String?  @default("DAILY")  // DAILY, ALT_DAYS, EVERY_3D, WEEKLY, SOS
  qty            String?  // String to support '1' for syrups and calculated values
  notesEn        String?
  notesHi        String?
  notesMr        String?
  sortOrder      Int      @default(0)

  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  medicine       Medicine     @relation(fields: [medicineId], references: [id])

  @@map("prescription_medicines")
}

model PrescriptionLabTest {
  id             String   @id @default(uuid())
  prescriptionId String
  labTestId      String
  labTestName    String
  referredTo     String?

  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  labTest        LabTest      @relation(fields: [labTestId], references: [id])

  @@map("prescription_lab_tests")
}

// ─────────────────────────────────────────────
// LAB RESULTS (Test Outcomes — recorded by doctor on a prescription)
// Hybrid storage: anchored to prescription (so it prints with the Rx) AND keyed to patient
// (so we can query historical trends across visits for charts).
// ─────────────────────────────────────────────

model LabResult {
  id             String   @id @default(uuid())
  clinicId       String
  patientId      String
  prescriptionId String?            // Null when recorded outside an Rx (future-proof)
  labTestId      String?            // Null when test isn't in catalog (free-text)
  testName       String             // Always denormalized for display
  testCategory   String?            // e.g., "Haematology"
  resultDate     DateTime           // The date the test was actually performed
  freeTextResult String?            // Used when labTest has no expectedFields (simple tests)
  notes          String?
  recordedById   String?            // User who recorded (doctor)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  clinic         Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient        Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  prescription   Prescription? @relation(fields: [prescriptionId], references: [id], onDelete: SetNull)
  labTest        LabTest?      @relation(fields: [labTestId], references: [id], onDelete: SetNull)
  values         LabResultValue[]

  @@index([patientId, resultDate])
  @@index([clinicId, resultDate])
  @@index([prescriptionId])
  @@map("lab_results")
}

model LabResultValue {
  id          String   @id @default(uuid())
  labResultId String
  fieldKey    String   // matches LabTest.expectedFields[].key — e.g., "hemoglobin"
  fieldLabel  String   // denormalized label e.g., "Hb"
  fieldUnit   String?  // e.g., "g/dL"
  value       String   // stored as string to support ranges, "Negative", numbers, etc.
  normalLow   Float?   // copied from expectedFields at record time (so trend charts have ranges)
  normalHigh  Float?

  labResult   LabResult @relation(fields: [labResultId], references: [id], onDelete: Cascade)

  @@index([labResultId])
  @@index([fieldKey])
  @@map("lab_result_values")
}

// ─────────────────────────────────────────────
// BILLING
// ─────────────────────────────────────────────

model Bill {
  id             String        @id @default(uuid())
  clinicId       String
  billNo         String
  date           DateTime      @default(now())
  patientId      String
  prescriptionId String?
  subtotal       Float         @default(0)
  discount       Float         @default(0)
  total          Float         @default(0)
  paymentMode    PaymentMode   @default(Cash)
  paymentStatus  PaymentStatus @default(Pending)
  amountPaid     Float         @default(0)
  balance        Float         @default(0)
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  clinic         Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient        Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  prescription   Prescription? @relation(fields: [prescriptionId], references: [id])
  items          BillItem[]

  @@unique([clinicId, billNo])
  @@map("bills")
}

model BillItem {
  id            String   @id @default(uuid())
  billId        String
  billingItemId String?
  name          String
  qty           Int      @default(1)
  rate          Float
  amount        Float

  bill          Bill        @relation(fields: [billId], references: [id], onDelete: Cascade)
  billingItem   BillingItem? @relation(fields: [billingItemId], references: [id])

  @@map("bill_items")
}

// ─────────────────────────────────────────────
// PAGE DESIGN
// ─────────────────────────────────────────────

model PageDesign {
  id         String   @id @default(uuid())
  clinicId   String
  name       String
  type       String   // prescription | bill | lab_referral
  isDefault  Boolean  @default(false)
  config     Json     @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  clinic     Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@map("page_designs")
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  clinicId  String
  userId    String?
  actorEmail String?            // For super admin entries (no User record)
  actorIsSuperAdmin Boolean @default(false)
  action    String
  entity    String
  entityId  String?
  details   Json?
  ip        String?
  createdAt DateTime @default(now())

  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])

  @@index([clinicId, createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// DOCTOR MEDICINE PREFERENCES (smart auto-fill)
// ─────────────────────────────────────────────
model DoctorMedicinePreference {
  id          String   @id @default(uuid())
  clinicId    String
  doctorId    String
  medicineId  String
  dosage      String?
  timing      String?
  days        String?  // e.g. '7 days', '2 weeks', '1 month'
  frequency   String?  // DAILY, ALT_DAYS, EVERY_3D, WEEKLY, SOS
  notesEn     String?
  notesHi     String?
  notesMr     String?
  usageCount  Int      @default(1)
  updatedAt   DateTime @updatedAt

  @@unique([clinicId, doctorId, medicineId])
  @@index([clinicId, doctorId, updatedAt])
  @@map("doctor_medicine_preferences")
}

// ─────────────────────────────────────────────
// SAVED REPORTS — custom report configs admins can save + rerun
// ─────────────────────────────────────────────

model SavedReport {
  id          String   @id @default(uuid())
  clinicId    String
  userId      String   // creator
  name        String
  description String?
  reportType  String   // 'patients' | 'prescriptions' | 'bills' | 'appointments'
  config      Json     // full filter / columns / sort / groupBy config
  isShared    Boolean  @default(true)  // false = private to creator
  lastRunAt   DateTime?
  runCount    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clinicId, userId])
  @@index([clinicId, reportType])
  @@map("saved_reports")
}

// ─────────────────────────────────────────────
// PRESCRIPTION DRAFTS — in-flight autosave snapshots
// ─────────────────────────────────────────────
// Upserted every ~10s while doctor is editing an unsaved prescription.
// One active draft per (doctor, patient) pair — newer writes overwrite older.
// Auto-deleted when prescription is saved, or by cleanup cron after 7 days.

model PrescriptionDraft {
  id         String   @id @default(uuid())
  clinicId   String
  doctorId   String
  patientId  String
  formState  Json     // full form snapshot { complaint, diagnosis, medicines, labTests, advice, vitals, nextVisit, ... }
  version    Int      @default(1)  // increments on each save (for optimistic concurrency in future)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([doctorId, patientId])
  @@index([clinicId, updatedAt])
  @@map("prescription_drafts")
}

// ─────────────────────────────────────────────
// MEDICAL DOCUMENTS — fitness certs, medical certs (sick leave), referrals
// ─────────────────────────────────────────────
// Single table, type-discriminated. The `data` JSON holds type-specific fields
// (verdict for fitness, restFrom/restTo for medical leave, referredTo for referral).

enum DocType {
  FITNESS_CERT     // "Patient is medically fit for X"
  MEDICAL_CERT     // "Patient was sick from A to B, advised rest"
  REFERRAL         // "Please see this patient — clinical context attached"
}

model MedicalDocument {
  id              String   @id @default(uuid())
  clinicId        String
  docNo           String   // e.g. MH-FC-0001, MH-MC-0001, MH-REF-0001
  type            DocType
  doctorId        String
  patientId       String   // required for all 3 types

  // Patient snapshot at time of issue (so doc stays correct if patient is later edited)
  patientName     String
  patientAge      Int?
  patientGender   Gender?
  patientGuardian String?  // S/o D/o W/o (relation + name)
  patientEmpId    String?  // employee/student ID (for medical certs)
  patientAddress  String?
  patientPhone    String?

  // Common medical fields
  examDate        DateTime  // when patient was examined
  diagnosis       String?
  remarks         String?

  // Type-specific fields stored as JSON
  // FITNESS_CERT  → { verdict, fitnessFor, restrictions, vitals: {bp,pulse,weight,...}, validityMonths }
  // MEDICAL_CERT  → { restFromDate, restToDate, totalDays, resumeFromDate, advisedRest }
  // REFERRAL      → { referredToName, referredToSpecialty, referredToClinic, referredToAddress,
  //                    referredToPhone, chiefComplaint, clinicalHistory, currentMeds,
  //                    investigations, provisionalDx, reasonForReferral, sourceRxId }
  data            Json     @default("{}")

  templateUsed    String?  // refs MedicalDocumentTemplate.id (for analytics)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  clinic          Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  doctor          User     @relation(fields: [doctorId], references: [id])
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([clinicId, docNo])
  @@index([clinicId, type, createdAt])
  @@index([patientId, createdAt])
  @@map("medical_documents")
}

// Reusable templates that pre-fill the doc form. Admin manages.
model MedicalDocumentTemplate {
  id          String   @id @default(uuid())
  clinicId    String
  type        DocType
  name        String   // e.g. "Sports fitness — adult", "Flu / viral fever (3-day rest)"
  isDefault   Boolean  @default(false)  // shown highlighted in picker

  // Pre-fill defaults — same shape as MedicalDocument.data, plus optional diagnosis/remarks
  diagnosis   String?
  remarks     String?
  data        Json     @default("{}")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clinic      Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, type, name])
  @@index([clinicId, type])
  @@map("medical_document_templates")
}
