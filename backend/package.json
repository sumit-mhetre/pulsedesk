{
  "name": "pulsedesk-backend",
  "version": "1.0.0",
  "description": "PulseDesk Backend API",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "migrate": "node scripts/guard-migrate-dev.js && dotenv -e .env.development -- npx prisma migrate dev",
    "migrate:status": "dotenv -e .env.development -- npx prisma migrate status",
    "migrate:status:prod": "dotenv -e .env -- npx prisma migrate status",
    "migrate:prod": "dotenv -e .env -- npx prisma migrate deploy",
    "generate": "npx prisma generate",
    "seed": "dotenv -e .env.development -- node src/seed.js",
    "studio": "dotenv -e .env.development -- npx prisma studio",
    "studio:prod": "dotenv -e .env -- npx prisma studio",
    "reset-super-local": "node scripts/reset-super-local.js",
    "postinstall": "npx prisma generate",
    "build": "npx prisma generate && npx prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^5.10.2",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "docx": "^8.5.0",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.18.3",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.15.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.2",
    "nodemon": "^3.1.0",
    "prisma": "^5.10.2"
  }
}